{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Propershare/tehuti-guard/decision-envelope.schema.json",
  "title": "TehutiGuardDecisionRequest",
  "type": "object",
  "required": ["machine_id", "actor", "action"],
  "properties": {
    "machine_id": { "type": "string", "minLength": 1 },
    "correlation_id": { "type": "string" },
    "actor": {
      "type": "object",
      "required": ["id", "role"],
      "properties": {
        "id": { "type": "string" },
        "role": { "type": "string" }
      }
    },
    "action": {
      "type": "object",
      "required": ["kind", "resource", "risk"],
      "properties": {
        "kind": { "type": "string" },
        "resource": { "type": "string" },
        "risk": {
          "enum": ["low", "medium", "high", "protected"]
        },
        "metadata": { "type": "object" }
      }
    },
    "raw_model_output": { "type": "string" },
    "covenant_record": { "type": "object" },
    "case": { "type": "object" }
  },
  "additionalProperties": true
}
